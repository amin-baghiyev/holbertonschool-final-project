@using PLDMS.BL.DTOs
@using PLDMS.Core.Enums
@model StudentSessionDetailDTO

@{
    ViewData["Title"] = Model.Name + " - Session Details";

    var statusColor = Model.SessionStatus switch
    {
        SessionStatus.Upcoming => "bg-yellow-100 text-yellow-700 border-yellow-200",
        SessionStatus.Active   => "bg-green-100 text-green-700 border-green-200",
        SessionStatus.Finished => "bg-gray-100 text-gray-700 border-gray-200",
        _                      => "bg-gray-100 text-gray-700 border-gray-200"
    };

    var now = DateTime.UtcNow.AddHours(4);
    var isActive = Model.SessionStatus == SessionStatus.Active;
    var remaining = Model.EndDate - now;
}

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0">
    <div class="flex items-center gap-4">
        <a asp-action="Index" class="text-gray-400 hover:text-brand-red transition-colors flex items-center gap-2">
            <i class="ph ph-arrow-left text-lg pb-0.5"></i>
            <span class="text-sm font-medium">Back</span>
        </a>
        <div class="h-6 w-px bg-gray-200"></div>
        <h1 class="text-xl font-bold text-gray-800">@Model.Name</h1>
        <span class="px-2.5 py-1 pt-1.5 rounded-full text-xs font-semibold uppercase tracking-wider border @statusColor">
            @Model.SessionStatus
        </span>
    </div>
</header>

<div class="flex-1 flex flex-col overflow-y-auto p-8 bg-gray-50/50">
    <div class="max-w-6xl mx-auto w-full space-y-8">

        <!-- Stats Cards Row -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <!-- Cohort / Program -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                    <i class="ph ph-stack text-2xl"></i>
                </div>
                <div class="overflow-hidden">
                    <p class="text-sm text-gray-500 font-medium">Cohort / Program</p>
                    <p class="text-gray-900 font-bold truncate" title="@Model.CohortName">@Model.CohortName</p>
                    <p class="text-xs text-gray-400 truncate" title="@Model.ProgramName">@Model.ProgramName</p>
                </div>
            </div>

            <!-- Schedule -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-orange-50 text-orange-600 flex items-center justify-center shrink-0">
                    <i class="ph ph-calendar-blank text-2xl"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Schedule</p>
                    <p class="text-gray-900 font-bold">@Model.StartDate.ToString("MMM dd, yyyy")</p>
                    <p class="text-xs text-gray-400">@Model.StartDate.ToString("HH:mm") to @Model.EndDate.ToString("HH:mm")</p>
                </div>
            </div>

            <!-- Your Group -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0">
                    <i class="ph ph-users-three text-2xl"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Your Group</p>
                    <p class="text-gray-900 font-bold">@Model.AssignedGroupName</p>
                    <p class="text-xs text-gray-400">@(Model.Teammates.Count + 1) members (incl. you)</p>
                </div>
            </div>

            <!-- Countdown / Repo -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center gap-4">
                @if (isActive)
                {
                    <div class="w-12 h-12 rounded-full bg-red-50 text-red-600 flex items-center justify-center shrink-0">
                        <i class="ph ph-timer text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Time Remaining</p>
                        @if (remaining.TotalHours >= 24)
                        {
                            <p class="text-gray-900 font-bold" id="countdown">@((int)remaining.TotalDays)d @(remaining.Hours)h</p>
                        }
                        else
                        {
                            <p class="text-gray-900 font-bold" id="countdown">@((int)remaining.TotalHours)h @(remaining.Minutes)m</p>
                        }
                        <p class="text-xs text-gray-400">Ends @Model.EndDate.ToString("dd MMM, HH:mm")</p>
                    </div>
                }
                else
                {
                    <div class="w-12 h-12 rounded-full bg-gray-50 text-gray-400 flex items-center justify-center shrink-0">
                        <i class="ph ph-check-circle text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Status</p>
                        <p class="text-gray-900 font-bold">Completed</p>
                        <p class="text-xs text-gray-400">Session has ended</p>
                    </div>
                }
            </div>
        </div>

        <!-- Main Two-Column Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left: Teammates -->
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4 flex items-center justify-between">
                        <h2 class="text-lg font-bold text-gray-800">
                            <i class="ph ph-users text-brand-red mr-1"></i> Your Teammates
                        </h2>
                        <span class="bg-brand-red/10 text-brand-red text-xs px-2 py-0.5 rounded-full font-semibold">
                            @Model.Teammates.Count
                        </span>
                    </div>
                    <ul class="divide-y divide-gray-100">
                        @if (Model.Teammates.Any())
                        {
                            foreach (var mate in Model.Teammates)
                            {
                                <li class="px-6 py-4 flex items-center gap-4 hover:bg-gray-50 transition-colors">
                                    <div class="w-9 h-9 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-sm shrink-0 border border-blue-100">
                                        @mate.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-medium text-gray-900 text-sm truncate">@mate.FullName</p>
                                        @if (!string.IsNullOrEmpty(mate.Email))
                                        {
                                            <p class="text-xs text-gray-400 truncate">
                                                <i class="ph ph-envelope-simple"></i> @mate.Email
                                            </p>
                                        }
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="p-8 text-center text-gray-500">
                                <i class="ph ph-user-plus text-3xl mb-2 text-gray-300 block"></i>
                                <p class="text-sm">No teammates assigned.</p>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Right: Assigned Tasks -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4 flex items-center justify-between">
                        <h2 class="text-lg font-bold text-gray-800">
                            <i class="ph ph-code text-brand-red mr-1"></i> Assigned Tasks
                        </h2>
                        <span class="bg-brand-red/10 text-brand-red text-xs px-2 py-0.5 rounded-full font-semibold">
                            @Model.Exercises.Count()
                        </span>
                    </div>
                    <div class="divide-y divide-gray-100">
                        @if (Model.Exercises.Any())
                        {
                            foreach (var exercise in Model.Exercises)
                            {
                                var diffColor = exercise.Difficulty switch
                                {
                                    ExerciseDifficulty.Easy   => "text-green-600 bg-green-50 border-green-200",
                                    ExerciseDifficulty.Medium => "text-yellow-600 bg-yellow-50 border-yellow-200",
                                    ExerciseDifficulty.Hard   => "text-red-600 bg-red-50 border-red-200",
                                    _                         => "text-gray-600 bg-gray-50 border-gray-200"
                                };

                                <div class="p-6 hover:bg-gray-50 transition-colors">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="min-w-0 flex-1">
                                            <h4 class="font-semibold text-gray-900 text-base">@exercise.Name</h4>
                                            <div class="flex gap-2 mt-2 flex-wrap items-center">
                                                <span class="inline-block px-2.5 py-0.5 text-xs font-bold uppercase tracking-wider rounded-md border @diffColor">
                                                    @exercise.Difficulty
                                                </span>
                                                @foreach (var lang in exercise.Languages)
                                                {
                                                    <span class="text-[10px] uppercase font-bold bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded">@lang</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-4">
                                            @if (exercise.PassCount.HasValue)
                                            {
                                                <div class="text-right">
                                                    <div class="flex items-center gap-1.5 @(exercise.IsSolved ? "text-green-600" : "text-red-500")">
                                                        <i class="ph ph-@(exercise.IsSolved ? "check-circle" : "x-circle") font-bold"></i>
                                                        <span class="text-xs font-bold">@(exercise.IsSolved ? "Solved" : "Attempted")</span>
                                                    </div>
                                                    <p class="text-[10px] text-gray-400 font-medium">@exercise.PassCount / @exercise.TotalTests passed</p>
                                                </div>
                                            }
                                            else if (!isActive)
                                            {
                                                <div class="text-right">
                                                    <div class="flex items-center gap-1.5 text-red-500">
                                                        <i class="ph ph-x-circle font-bold"></i>
                                                        <span class="text-xs font-bold">Unsolved</span>
                                                    </div>
                                                    <p class="text-[10px] text-gray-400 font-medium">Session ended</p>
                                                </div>
                                            }

                                            <a asp-controller="Exercise" asp-action="Details"
                                               asp-route-exerciseId="@exercise.Id"
                                               asp-route-groupId="@Model.AssignedGroupId"
                                               class="shrink-0 bg-gray-900 hover:bg-gray-800 text-white px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm flex items-center gap-2">
                                                <i class="ph ph-code"></i> @(!isActive || exercise.PassCount.HasValue ? "View Code" : "Solve")
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-8 text-center text-gray-500">
                                <i class="ph ph-code text-3xl mb-2 text-gray-300 block"></i>
                                <p>No tasks assigned for this session.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@if (isActive)
{
    <script>
        (function() {
            // EndDate is stored in UTC+4 — parse as local time (user is in UTC+4)
            var parts = '@Model.EndDate.ToString("yyyy-MM-dd HH:mm:ss")'.split(/[- :]/);
            var endTime = new Date(parts[0], parts[1]-1, parts[2], parts[3], parts[4], parts[5]).getTime();
            var el = document.getElementById('countdown');
            if (!el) return;
            setInterval(function() {
                var now = new Date().getTime();
                var diff = endTime - now;
                if (diff <= 0) { el.textContent = 'Time is up!'; return; }
                var d = Math.floor(diff / 86400000);
                var h = Math.floor((diff % 86400000) / 3600000);
                var m = Math.floor((diff % 3600000) / 60000);
                var s = Math.floor((diff % 60000) / 1000);
                el.textContent = d > 0 ? d + 'd ' + h + 'h ' + m + 'm' : h + 'h ' + m + 'm ' + s + 's';
            }, 1000);
        })();
    </script>
}
