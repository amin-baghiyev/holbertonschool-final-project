@model ICollection<StudentReviewListItemDTO>

@{
    ViewData["Title"] = "My Reviews";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0">
    <h1 class="text-xl font-bold text-gray-800">My Reviews</h1>
</header>

<div class="flex-1 flex flex-col overflow-hidden p-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 shrink-0">
        <div>
            <h2 class="text-lg font-semibold text-gray-900">Assigned Reviews</h2>
            <p class="text-sm text-gray-500">View and complete peer reviews assigned to you.</p>
        </div>

        <div class="flex gap-3">
            <form asp-action="Index" method="get" class="flex flex-wrap gap-3 items-center">
                <select name="status" class="bg-white border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-red-400" onchange="this.form.submit()">
                    <option value="">Status: All</option>
                    <option value="Pending">Pending</option>
                    <option value="Reviewed">Reviewed</option>
                </select>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="flex-1 flex flex-col bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="flex-1 overflow-y-auto">
            <table class="w-full text-left border-collapse">
                <thead class="sticky top-0 bg-gray-50 z-10 shadow-[0_1px_0_0_#e5e7eb]">
                    <tr class="text-sm font-semibold text-gray-600">
                        <th class="px-6 py-4">Group</th>
                        <th class="px-6 py-4">Assigned By</th>
                        <th class="px-6 py-4 text-center">Score</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm bg-white divide-gray-200">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var statusColor = item.ReviewStatus switch
                            {
                                ReviewStatus.Pending => "bg-yellow-100 text-yellow-700",
                                ReviewStatus.UnderReview => "bg-blue-100 text-blue-700",
                                ReviewStatus.Reviewed => "bg-green-100 text-green-700",
                                ReviewStatus.Accepted => "bg-purple-100 text-purple-700",
                                ReviewStatus.Rejected => "bg-red-100 text-red-700",
                                _ => "bg-gray-100 text-gray-700"
                            };

                            var canReview = item.ReviewStatus == ReviewStatus.Pending || item.ReviewStatus == ReviewStatus.UnderReview;

                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 font-medium text-gray-900">@item.GroupName</td>
                                <td class="px-6 py-4 text-gray-600">@item.AssignedByName</td>
                                <td class="px-6 py-4 text-center font-semibold text-gray-900">
                                    @(item.ReviewStatus == ReviewStatus.Pending || item.ReviewStatus == ReviewStatus.UnderReview ? "-" : item.Score.ToString())
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusColor">@item.ReviewStatus</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    @if (canReview)
                                    {
                                        <a asp-action="Create" asp-route-id="@item.Id" class="inline-flex items-center gap-1 bg-red-50 text-red-600 hover:bg-red-100 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors">
                                            <i class="ph ph-pencil-simple"></i> Review Setup
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400 italic text-xs">Completed</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-12 text-center bg-gray-50 border border-dashed rounded-xl m-4">
                                <div class="flex justify-center mb-2"><i class="ph ph-clipboard-text text-4xl text-gray-300"></i></div>
                                <p class="text-gray-500">No reviews found matching your criteria.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 bg-white shrink-0">
            <div class="text-sm text-gray-500">
                Total Results: <span class="font-medium text-gray-900">@totalCount</span>
            </div>
            <div class="flex gap-2">
                @if (currentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" class="px-3 py-1.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Previous</a>
                }
                @if (currentPage < totalPages)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" class="px-3 py-1.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Next</a>
                }
            </div>
        </div>
    </div>
</div>
