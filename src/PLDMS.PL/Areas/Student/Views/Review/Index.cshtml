@model ICollection<PLDMS.BL.DTOs.StudentReviewListItemDTO>
@using PLDMS.Core.Enums

@{
    ViewData["Title"] = "My Reviews";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    int pageSize = ViewBag.PageSize as int? ?? 10;

    var startItem = totalCount == 0 ? 0 : (currentPage - 1) * pageSize + 1;
    var endItem = Math.Min(currentPage * pageSize, totalCount);

    var statusParam = Context.Request.Query["status"].ToString();
    var hasSearch = !string.IsNullOrWhiteSpace(statusParam);
}

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0">
    <h1 class="text-xl font-bold text-gray-800">Peer Reviews</h1>
</header>

<div class="flex-1 flex flex-col overflow-hidden p-8">
    
    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 shrink-0">
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-red-50 text-brand-red rounded-lg flex items-center justify-center">
                <i class="ph ph-warning-circle text-2xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium uppercase tracking-wider">Awaiting Review</p>
                <p class="text-2xl font-bold text-gray-900">@Model.Count(r => r.ReviewStatus == ReviewStatus.Pending)</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-green-50 text-green-600 rounded-lg flex items-center justify-center">
                <i class="ph ph-check-circle text-2xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium uppercase tracking-wider">Completed Feedback</p>
                <p class="text-2xl font-bold text-gray-900">@Model.Count(r => r.ReviewStatus != ReviewStatus.Pending)</p>
            </div>
        </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 shrink-0">
        <div>
            <h2 class="text-lg font-semibold text-gray-900">Peer Review Center</h2>
            <p class="text-sm text-gray-500">Provide constructive feedback to your peers and verify assigned sessions.</p>
        </div>

        <div class="flex gap-3">
            <form asp-action="Index" method="get" class="flex flex-wrap gap-4 items-end">
                <div class="flex flex-col">
                    <label class="text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wider">Status</label>
                    <select name="status" onchange="this.form.submit()" class="bg-white border rounded-lg px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-brand-red/20 transition-all min-w-[150px]">
                        <option value="">All Assignments</option>
                        <option value="Pending" selected="@(statusParam == "Pending")">Pending</option>
                        <option value="Reviewed" selected="@(statusParam == "Reviewed")">Reviewed</option>
                    </select>
                </div>
                @if (hasSearch)
                {
                    <a asp-action="Index" class="bg-gray-100 hover:bg-gray-200 text-gray-600 py-2.5 px-4 rounded-lg transition-all flex items-center justify-center">
                        <i class="ph ph-arrow-counter-clockwise text-lg"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 flex items-center gap-3 bg-green-50 border border-green-200 text-green-700 px-6 py-4 rounded-xl animate-fade-in shadow-sm">
            <i class="ph ph-check-circle text-xl"></i>
            <span class="font-bold text-sm">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="flex-1 flex flex-col bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="flex-1 overflow-y-auto">
            <table class="w-full text-left border-collapse">
                <thead class="sticky top-0 bg-gray-50 z-10 shadow-[0_1px_0_0_#e5e7eb]">
                    <tr class="text-sm font-semibold text-gray-600">
                        <th class="px-6 py-4">Reviewed Group</th>
                        <th class="px-6 py-4">Assigned By</th>
                        <th class="px-6 py-4 text-center">Score</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm bg-white divide-gray-200">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var statusColor = item.ReviewStatus switch
                            {
                                ReviewStatus.Pending => "bg-yellow-100 text-yellow-700",
                                ReviewStatus.Reviewed => "bg-green-100 text-green-700",
                                _ => "bg-gray-100 text-gray-700"
                            };

                            var canReview = item.ReviewStatus == ReviewStatus.Pending || item.ReviewStatus == ReviewStatus.UnderReview;

                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center text-gray-500 border border-gray-200">
                                            <i class="ph ph-users-three text-lg"></i>
                                        </div>
                                        <div class="font-medium text-gray-900">@item.GroupName</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-600">
                                    <div class="flex items-center gap-2">
                                        <i class="ph ph-user-circle text-lg opacity-40"></i>
                                        @item.AssignedByName
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (canReview)
                                    {
                                        <span class="text-gray-300 font-medium">--</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-gray-900 text-white rounded-lg text-xs font-bold">
                                            @item.Score / 10
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusColor">
                                        @item.ReviewStatus
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <a asp-action="Detail" asp-route-id="@item.Id" 
                                           class="p-2 transition-all @(canReview ? "text-brand-red hover:bg-red-50" : "text-gray-400 hover:text-brand-dark hover:bg-gray-100") rounded-lg"
                                           title="@(canReview ? "Complete Review" : "View Details")">
                                            <i class="ph @(canReview ? "ph-pencil-simple" : "ph-eye") text-xl"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-12 text-center">
                                <div class="flex justify-center mb-2"><i class="ph ph-sparkle text-4xl text-gray-300"></i></div>
                                <p class="text-gray-500">
                                    @(hasSearch ? "No peer review assignments matching your filters." : "You have no peer review assignments at the moment.")
                                </p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 bg-white shrink-0">
            <div class="flex items-center gap-6">
                <div class="hidden sm:block text-sm text-gray-500">
                    Showing <span class="font-medium text-gray-900">@startItem</span> - <span class="font-medium text-gray-900">@endItem</span> of <span class="font-medium text-gray-900">@totalCount</span> results
                </div>

                <form method="get" asp-action="Index" class="flex items-center gap-2 text-sm">
                    <input type="hidden" name="status" value="@statusParam" />
                    <input type="hidden" name="page" value="1" />
                    <span class="text-gray-500">Show</span>
                    <select name="pageSize" onchange="this.form.submit()" class="border border-gray-200 rounded-lg px-2 py-1 text-gray-700 focus:outline-none focus:ring-1 focus:ring-red-400">
                        <option value="5" selected="@(pageSize == 5)">5</option>
                        <option value="10" selected="@(pageSize == 10)">10</option>
                        <option value="15" selected="@(pageSize == 15)">15</option>
                        <option value="20" selected="@(pageSize == 20)">20</option>
                        <option value="25" selected="@(pageSize == 25)">25</option>
                    </select>
                    <span class="text-gray-500">per page</span>
                </form>
            </div>

            <div class="flex gap-2">
                <a asp-action="Index" asp-route-status="@statusParam" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(currentPage == 1 ? "border-gray-200 text-gray-400 bg-gray-50 pointer-events-none" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    Previous
                </a>
                <div class="hidden sm:flex gap-1">
                    @for (var i = 1; i <= totalPages; i++)
                    {
                        <a asp-action="Index" asp-route-status="@statusParam" asp-route-page="@i" asp-route-pageSize="@pageSize"
                           class="px-3 py-1.5 border rounded-lg text-sm font-medium transition-colors @(i == currentPage ? "border-red-200 bg-red-50 text-red-600" : "border-transparent text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                            @i
                        </a>
                    }
                </div>
                <a asp-action="Index" asp-route-status="@statusParam" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(currentPage == totalPages ? "border-gray-200 text-gray-400 bg-gray-50 pointer-events-none" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    Next
                </a>
            </div>
        </div>
    </div>
</div>
