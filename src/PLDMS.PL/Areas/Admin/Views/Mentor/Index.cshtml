@using PLDMS.BL.DTOs.MentorDTOs
@using PLDMS.PL.Areas.Admin.ViewModels
@model MentorVM

@{
    var hasSearch = !string.IsNullOrWhiteSpace(Context.Request.Query["q"]);
    var startItem = Model.TotalCount == 0 ? 0 : Model.CurrentPage * Model.PageSize + 1;
    var endItem = Math.Min((Model.CurrentPage + 1) * Model.PageSize, Model.TotalCount);
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0">
    <h1 class="text-xl font-bold text-gray-800">Mentor Management</h1>
    <button class="add-mentor-btn flex items-center gap-2 bg-brand-red hover:bg-red-700 text-white px-5 py-2.5 rounded-lg font-medium transition-all shadow-sm">
        <i class="ph ph-plus-circle text-lg"></i>
        <span class="hidden sm:inline">Add Mentor</span>
    </button>
    <partial name="_MentorModal" model="new MentorFormDTO()" />
</header>

<div class="flex-1 flex flex-col overflow-hidden p-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 shrink-0">
        <div>
            <h2 class="text-lg font-semibold text-gray-900">Mentors</h2>
            <p class="text-sm text-gray-500">Manage mentor accounts and access.</p>
        </div>

        <div class="flex gap-3">
            <form asp-action="Index" method="get" class="flex flex-wrap gap-4 items-end">
                <div class="flex flex-col">
                    <label class="text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wider">Status</label>
                    <select name="onlyActive" class="bg-white border rounded-lg px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-brand-red/20 transition-all min-w-[140px]">
                        <option value="true" selected="@(Context.Request.Query["onlyActive"] == "true" || string.IsNullOrEmpty(Context.Request.Query["onlyActive"]))">Active Only</option>
                        <option value="false" selected="@(Context.Request.Query["onlyActive"] == "false")">Include Deactives</option>
                    </select>
                </div>
                
                <div class="flex flex-col">
                    <label class="text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wider">Search</label>
                    <div class="flex items-center bg-white border rounded-lg px-3 py-2.5 focus-within:ring-2 focus-within:ring-brand-red/20 transition-all">
                        <i class="ph ph-magnifying-glass text-gray-400 mr-2"></i>
                        <input type="text" name="q" value="@Context.Request.Query["q"]"
                               placeholder="Search by name or email..."
                               class="outline-none text-sm w-40 md:w-64 bg-transparent">
                        @if (hasSearch)
                        {
                            <a asp-action="Index" class="ml-2 text-gray-400 hover:text-brand-red">
                                <i class="ph ph-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>

                <button type="submit" class="bg-brand-red hover:bg-red-700 py-2.5 px-5 rounded-lg transition-all shadow-sm">
                    <i class="ph ph-magnifying-glass text-white font-large"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="flex-1 flex flex-col bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="flex-1 overflow-y-auto">
            @if (Model.Mentors != null && Model.Mentors.Any())
            {
                <table class="min-w-full">
                    <thead class="sticky top-0 bg-gray-50 z-10 shadow-[0_1px_0_0_#e5e7eb]">
                        <tr class="text-sm font-semibold text-gray-600">
                            <th class="px-6 py-4 text-left">Full Name</th>
                            <th class="px-6 py-4 text-left">Email</th>
                            <th class="px-6 py-4 text-left">Creation Time</th>
                            <th class="px-6 py-4 text-center">Status</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-sm">
                        @foreach (var item in Model.Mentors)
                        {
                            var isDeleted = item.IsDeleted;
                            var actionType = isDeleted ? "Activate" : "Deactivate";
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 font-medium text-gray-900">@item.FullName</td>
                                <td class="px-6 py-4 text-gray-600">@item.Email</td>
                                <td class="px-6 py-4 text-gray-600">@item.CreatedAt</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-2.5 py-1 @(isDeleted ? "bg-red-50 text-red-700" : "bg-green-50 text-green-700") rounded-lg font-medium">
                                        @(isDeleted ? "Deactive" : "Active")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <button class="edit-btn text-gray-500 mr-2 hover:text-blue-600"
                                            data-id="@item.Id"
                                            data-fullname="@item.FullName"
                                            data-email="@item.Email"
                                            >
                                        <i class="ph ph-pencil-simple text-lg"></i>
                                    </button>

                                    <button data-url="@Url.Action(actionType, "Mentor", new { id = item.Id })"
                                            data-type="@actionType"
                                            data-name="@item.FullName"
                                            class="power-btn text-gray-500 @(isDeleted ? "hover:text-green-600" : "hover:text-brand-red")">
                                        <i class="ph ph-power text-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="py-12 text-center bg-gray-50 border border-dashed rounded-xl">
                    <i class="ph ph-users text-4xl text-gray-300 mb-2"></i>
                    <p class="text-gray-500">@(hasSearch ? "No mentors match your search." : "No mentors registered yet.")</p>
                </div>
            }
        </div>

        @* Pagination Footer *@
        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 bg-white shrink-0">
            <div class="flex items-center gap-6">
                <div class="hidden sm:block text-sm text-gray-500">
                    Showing <span class="font-medium text-gray-900">@startItem</span> - <span class="font-medium text-gray-900">@endItem</span> of <span class="font-medium text-gray-900">@Model.TotalCount</span>
                </div>
                <form method="get" asp-action="Index" class="flex items-center gap-2 text-sm">
                    <input type="hidden" name="q" value="@Model.Search" />
                    <input type="hidden" name="onlyActive" value="@Context.Request.Query["onlyActive"]" />
                    <input type="hidden" name="page" value="0" />
                    <select name="pageSize" onchange="this.form.submit()" class="border border-gray-200 rounded-lg px-2 py-1 text-gray-700 outline-none">
                        @foreach (var size in new[] { 5, 10, 15, 20 })
                        {
                            <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                        }
                    </select>
                    <span class="text-gray-500">per page</span>
                </form>
            </div>

            <div class="flex gap-2">
                <a asp-action="Index" asp-route-q="@Model.Search" asp-route-onlyActive="@Context.Request.Query["onlyActive"]" asp-route-page="@(Model.CurrentPage - 1)" asp-route-pageSize="@Model.PageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(Model.CurrentPage == 0 ? "opacity-50 pointer-events-none bg-gray-50" : "hover:bg-gray-50")">
                    Previous
                </a>
                <div class="hidden sm:flex gap-1">
                    @for (var i = 0; i < totalPages; i++)
                    {
                        <a asp-action="Index" asp-route-q="@Model.Search" asp-route-onlyActive="@Context.Request.Query["onlyActive"]" asp-route-page="@i" asp-route-pageSize="@Model.PageSize"
                           class="px-3 py-1.5 border rounded-lg text-sm font-medium @(i == Model.CurrentPage ? "border-red-200 bg-red-50 text-red-600" : "border-transparent hover:bg-gray-50")">
                            @(i + 1)
                        </a>
                    }
                </div>
                <a asp-action="Index" asp-route-q="@Model.Search" asp-route-onlyActive="@Context.Request.Query["onlyActive"]" asp-route-page="@(Model.CurrentPage + 1)" asp-route-pageSize="@Model.PageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(Model.CurrentPage >= totalPages - 1 ? "opacity-50 pointer-events-none bg-gray-50" : "hover:bg-gray-50")">
                    Next
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/admin/mentor.js"></script>
}