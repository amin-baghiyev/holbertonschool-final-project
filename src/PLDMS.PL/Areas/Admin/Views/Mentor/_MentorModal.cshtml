@using PLDMS.BL.DTOs.MentorDTOs
@model MentorFormDTO

<div id="mentorModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="modal-overlay fixed inset-0 bg-gray-900/50 transition-opacity"></div>

    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
            <form id="mentorForm">
                @Html.AntiForgeryToken()
                
                <div class="p-6">
                    <h3 id="modalTitle" class="text-xl font-bold mb-6 text-gray-800">Create New Mentor</h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label asp-for="FullName" class="block text-sm font-medium text-gray-700">Full Name</label>
                            <input asp-for="FullName" type="text" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-2 focus:ring-brand-red/20 border-gray-200 outline-none transition-all" placeholder="John Doe">
                            <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1"></span>
                        </div>

                        <div>
                            <label asp-for="Email" class="block text-sm font-medium text-gray-700">Email Address</label>
                            <input asp-for="Email" type="email" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-2 focus:ring-brand-red/20 border-gray-200 outline-none transition-all" placeholder="mentor@pldms.com">
                            <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                        </div>

                        <div>
                            <label asp-for="UserName" class="block text-sm font-medium text-gray-700">Username</label>
                            <input asp-for="UserName" type="text" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-2 focus:ring-brand-red/20 border-gray-200 outline-none transition-all" placeholder="johndoe123">
                            <span asp-validation-for="UserName" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>

                </div>
                    <p class="pb-2 text-xs text-red-600 font-medium text-center">@Html.ValidationMessage("Error")</p>

                <div class="bg-gray-50 px-6 py-4 flex justify-end gap-3">
                    <button type="button" class="cancel-btn px-4 py-2 text-gray-600 hover:bg-gray-200 rounded-lg transition-colors">Cancel</button>
                    <button type="submit" class="bg-brand-red hover:bg-red-700 text-white px-6 py-2 rounded-lg font-medium shadow-sm transition-all">Save Mentor</button>
                </div>
            </form>
        </div>
    </div>
</div>