@using PLDMS.BL.DTOs.DashboardDTOs
@model AdminDashboardStatsDTO

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8">
    <h1 class="text-xl font-bold text-gray-800">Admin Overview</h1>
</header>

<div class="flex-1 overflow-y-auto p-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-sm font-medium text-gray-500">Total Users</p>
                    <h3 class="text-3xl font-bold text-gray-900 mt-2">@Model.TotalUsers</h3>
                </div>
                <div class="p-2 bg-blue-50 text-blue-600 rounded-lg">
                    <i class="ph ph-users text-2xl"></i>
                </div>
            </div>
            <div class="mt-4 flex items-center text-sm text-gray-500">
                <span>@Model.TotalStudents Students • @Model.TotalMentors Mentors</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-sm font-medium text-gray-500">Active Cohorts</p>
                    <h3 class="text-3xl font-bold text-gray-900 mt-2">@Model.ActiveCohorts</h3>
                </div>
                <div class="p-2 bg-purple-50 text-purple-600 rounded-lg">
                    <i class="ph ph-stack text-2xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-sm font-medium text-gray-500">Active Programs</p>
                    <h3 class="text-3xl font-bold text-gray-900 mt-2">@Model.ActivePrograms</h3>
                </div>
                <div class="p-2 bg-orange-50 text-orange-600 rounded-lg">
                    <i class="ph ph-book-open text-2xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-sm font-medium text-gray-500">New Registrations</p>
                    <h3 class="text-3xl font-bold text-gray-900 mt-2">@Model.NewRegistrations</h3>
                </div>
                <div class="p-2 bg-green-50 text-green-600 rounded-lg">
                    <i class="ph ph-user-circle-plus text-2xl"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-bold text-gray-800 mb-6">System Activity</h2>
            <div class="space-y-6">
                @if (Model.RecentActivities == null || !Model.RecentActivities.Any())
                {
                    <p class="text-gray-500 text-sm">No recent activity.</p>
                }
                else
                {
                    @foreach (var activity in Model.RecentActivities)
                    {
                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full @activity.BgClass @activity.TextColorClass flex items-center justify-center flex-shrink-0">
                                <i class="ph @activity.IconClass text-lg"></i>
                            </div>
                            <div>
                                <p class="text-sm text-gray-800">@Html.Raw(activity.ActionTextHtml)</p>
                                <p class="text-xs text-gray-500 mt-1">@activity.SubText</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-bold text-gray-800 mb-6">Admin Actions</h2>
            <div class="space-y-3">
                <button onclick="window.location.href='/Admin/Mentor?action=new'" class="w-full flex items-center justify-between p-3 rounded-lg border border-gray-200 hover:border-brand-red hover:text-brand-red transition-all group">
                    <span class="font-medium text-sm">Add New Mentor</span>
                    <i class="ph ph-user-plus text-gray-400 group-hover:text-brand-red"></i>
                </button>
                <button onclick="window.location.href='/Admin/Student?action=new'" class="w-full flex items-center justify-between p-3 rounded-lg border border-gray-200 hover:border-brand-red hover:text-brand-red transition-all group">
                    <span class="font-medium text-sm">Add New Student</span>
                    <i class="ph ph-user-plus text-gray-400 group-hover:text-brand-red"></i>
                </button>
                <button onclick="window.location.href='/Admin/Cohort?action=new'" class="w-full flex items-center justify-between p-3 rounded-lg border border-gray-200 hover:border-brand-red hover:text-brand-red transition-all group">
                    <span class="font-medium text-sm">Create New Cohort</span>
                    <i class="ph ph-stack-plus text-gray-400 group-hover:text-brand-red"></i>
                </button>
                <button onclick="window.location.href='/Admin/Program?action=new'" class="w-full flex items-center justify-between p-3 rounded-lg border border-gray-200 hover:border-brand-red hover:text-brand-red transition-all group">
                    <span class="font-medium text-sm">Add New Program</span>
                    <i class="ph ph-folder-plus text-gray-400 group-hover:text-brand-red"></i>
                </button>
            </div>
        </div>
    </div>
</div>