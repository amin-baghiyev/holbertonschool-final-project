@model SessionVM

@{
    var hasSearch = !string.IsNullOrWhiteSpace(Context.Request.Query["q"]) || !string.IsNullOrWhiteSpace(Context.Request.Query["status"]);

    // Pagination Calculations
    var startItem = Model.TotalCount == 0
        ? 0
        : Model.CurrentPage * Model.PageSize + 1;

    var endItem = Math.Min(
        (Model.CurrentPage + 1) * Model.PageSize,
        Model.TotalCount
    );

    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0">
    <h1 class="text-xl font-bold text-gray-800">Sessions</h1>

    <button class="add-session flex items-center gap-2 bg-brand-red hover:bg-red-700 text-white px-5 py-2.5 rounded-lg font-medium transition-all shadow-sm">
        <i class="ph ph-plus-circle text-lg"></i>
        <span class="hidden sm:inline">Add Session</span>
    </button>
</header>

<div class="flex-1 flex flex-col overflow-hidden p-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 shrink-0">
        <div>
            <h2 class="text-lg font-semibold text-gray-900">Educational Sessions</h2>
            <p class="text-sm text-gray-500">Manage your active, upcoming, and finished sessions.</p>
        </div>

        <div class="flex gap-3">
            <form asp-action="Index" method="get" class="flex flex-wrap gap-3 items-center">

                <select name="status" class="bg-white border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-red/20 transition-all">
                    <option value="">Status: All</option>
                    <option value="Upcoming" selected="@(Model.Status?.ToString() == "Upcoming")">Upcoming</option>
                    <option value="Active" selected="@(Model.Status?.ToString() == "Active")">Active</option>
                    <option value="Finished" selected="@(Model.Status?.ToString() == "Finished")">Finished</option>
                </select>

                <div class="flex items-center bg-white border rounded-lg px-3 py-2 focus-within:ring-2 focus-within:ring-brand-red/20 transition-all">
                    <i class="ph ph-magnifying-glass text-gray-400 mr-2"></i>
                    <input type="text" name="q" value="@Model.Search"
                           placeholder="Search by name..."
                           class="outline-none text-sm w-40 md:w-56 bg-transparent">
                    @if (hasSearch)
                    {
                        <a asp-action="Index" class="ml-2 text-gray-400 hover:text-brand-red"><i class="ph ph-x-circle"></i></a>
                    }
                </div>

                <button type="submit" class="bg-brand-red hover:bg-red-700 py-2.5 px-4 rounded-lg transition-all shadow-sm">
                    <i class="ph ph-magnifying-glass text-white text-lg"></i>
                </button>
            </form>
        </div>

        <partial name="_SessionModal" model="new SessionFormDTO()" />
    </div>

    <div class="flex-1 flex flex-col bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">

        <div class="flex-1 overflow-y-auto">
            <table class="w-full text-left border-collapse">
                <thead class="sticky top-0 bg-gray-50 z-10 shadow-[0_1px_0_0_#e5e7eb]">
                    <tr class="text-sm font-semibold text-gray-600">
                        <th class="px-6 py-4">Session Name</th>
                        <th class="px-6 py-4">Cohort / Program</th>
                        <th class="px-6 py-4">Time Range</th>
                        <th class="px-6 py-4 text-center">Students</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm bg-white divide-gray-200">
                    @if (Model.Sessions != null && Model.Sessions.Count != 0)
                    {
                        foreach (var item in Model.Sessions)
                        {
                            var isStarted = item.StartDate <= DateTime.UtcNow;
                            var statusColor = item.SessionStatus switch
                            {
                                SessionStatus.Upcoming => "bg-yellow-100 text-yellow-700",
                                SessionStatus.Active => "bg-green-100 text-green-700",
                                SessionStatus.Finished => "bg-gray-100 text-gray-700",
                                _ => "bg-gray-100 text-gray-700"
                            };

                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 font-medium text-gray-900">@item.Name</td>
                                <td class="px-6 py-4">
                                    <div class="text-gray-900 font-medium">@item.CohortName</div>
                                    <div class="text-xs text-gray-500">@item.ProgramName</div>
                                </td>
                                <td class="px-6 py-4 text-gray-600">
                                    <div>@item.StartDate.ToString("dd MMM yyyy HH:mm")</div>
                                    <div class="text-xs text-gray-400">to @item.EndDate.ToString("dd MMM yyyy HH:mm")</div>
                                </td>
                                <td class="px-6 py-4 text-center text-gray-600">
                                    <span class="bg-blue-50 text-blue-700 px-2 py-1 rounded font-medium">@item.TotalStudentCount</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusColor">
                                        @item.SessionStatus
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right space-x-3">
                                    <button class="edit-btn text-gray-500 hover:text-blue-600 transition-colors"
                                            data-id="@item.Id"
                                            title="Edit Session">
                                        <i class="ph ph-pencil-simple text-lg"></i>
                                    </button>

                                    @if (!isStarted)
                                    {
                                        <button class="trash-btn text-gray-500 hover:text-brand-red transition-colors"
                                                data-id="@item.Id"
                                                data-name="@item.Name"
                                                title="Delete Session">
                                            <i class="ph ph-trash text-lg"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400 italic text-xs cursor-not-allowed" title="Cannot delete started sessions">Locked</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-12 text-center bg-gray-50 border border-dashed rounded-xl m-4">
                                <div class="flex justify-center mb-2"><i class="ph ph-calendar-blank text-4xl text-gray-300"></i></div>
                                <p class="text-gray-500">
                                    @(hasSearch ? "No sessions found matching your filters." : "There are no sessions yet.")
                                </p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 bg-white shrink-0">

            <div class="flex items-center gap-6">
                <div class="hidden sm:block text-sm text-gray-500">
                    Showing
                    <span class="font-medium text-gray-900">@startItem</span>
                    -
                    <span class="font-medium text-gray-900">@endItem</span>
                    of
                    <span class="font-medium text-gray-900">@Model.TotalCount</span>
                    results
                </div>

                <form method="get" asp-action="Index" class="flex items-center gap-2 text-sm">
                    <input type="hidden" name="q" value="@Model.Search" />
                    <input type="hidden" name="status" value="@Model.Status" />
                    <input type="hidden" name="page" value="0" />

                    <span class="text-gray-500">Show</span>
                    <select name="pageSize"
                            onchange="this.form.submit()"
                            class="border border-gray-200 rounded-lg px-2 py-1 text-gray-700 focus:outline-none focus:ring-1 focus:ring-red-400">
                        <option value="5" selected="@(Model.PageSize == 5)">5</option>
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="15" selected="@(Model.PageSize == 15)">15</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    </select>
                    <span class="text-gray-500">per page</span>
                </form>
            </div>

            <div class="flex gap-2">

                <a asp-action="Index"
                   asp-route-q="@Model.Search"
                   asp-route-status="@Model.Status"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(Model.CurrentPage == 0 ? "border-gray-200 text-gray-400 bg-gray-50 pointer-events-none" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    Previous
                </a>

                <div class="hidden sm:flex gap-1">
                    @for (var i = 0; i < totalPages; i++)
                    {
                        <a asp-action="Index"
                           asp-route-q="@Model.Search"
                           asp-route-status="@Model.Status"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize"
                           class="px-3 py-1.5 border rounded-lg text-sm font-medium transition-colors @(i == Model.CurrentPage ? "border-red-200 bg-red-50 text-red-600" : "border-transparent text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                            @(i + 1)
                        </a>
                    }
                </div>

                <a asp-action="Index"
                   asp-route-q="@Model.Search"
                   asp-route-status="@Model.Status"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(Model.CurrentPage >= totalPages - 1 ? "border-gray-200 text-gray-400 bg-gray-50 pointer-events-none" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    Next
                </a>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/mentor/session.js"></script>
}