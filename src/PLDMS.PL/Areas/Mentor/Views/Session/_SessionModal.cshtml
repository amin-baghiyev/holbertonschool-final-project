@model SessionFormDTO

<div id="addSessionModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="modal-overlay fixed inset-0 bg-gray-900 bg-opacity-50 transition-opacity"></div>

    <div class="flex items-center justify-center min-h-screen p-4">
        <div id="modalContent" class="relative bg-white rounded-xl shadow-xl w-full max-w-2xl overflow-hidden">
            <form id="createSessionForm">
                @Html.AntiForgeryToken()
                
                <div class="p-6">
                    <h3 id="modalTitle" class="text-xl font-bold mb-6">Create New Session</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Session Name</label>
                                <input asp-for="Name" type="text" placeholder="Leave empty to auto-generate" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none">
                                <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Cohort</label>
                                <select asp-for="CohortId" asp-items="ViewBag.Cohorts" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none">
                                    <option value="">-- Select Cohort --</option>
                                </select>
                                <span asp-validation-for="CohortId" class="text-red-500 text-xs mt-1"></span>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700">Students Per Group</label>
                                <input asp-for="StudentCountPerGroup" type="number" min="1" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none">
                                <span asp-validation-for="StudentCountPerGroup" class="text-red-500 text-xs mt-1"></span>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Start Time</label>
                                <input asp-for="StartDate" type="datetime-local" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none">
                                <span asp-validation-for="StartDate" class="text-red-500 text-xs mt-1"></span>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700">End Time</label>
                                <input asp-for="EndDate" type="datetime-local" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none">
                                <span asp-validation-for="EndDate" class="text-red-500 text-xs mt-1"></span>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700">Exercises</label>
                                <select asp-for="ExercisesIds" asp-items="ViewBag.Exercises" multiple class="w-full mt-1 border rounded-lg p-2.5 h-24 focus:ring-brand-red outline-none">
                                </select>
                                <span asp-validation-for="ExercisesIds" class="text-red-500 text-xs mt-1"></span>
                            </div>
                        </div>
                    </div>

                    <p class="mt-1 text-xs text-red-600 font-medium text-center">@Html.ValidationMessage("Error")</p>
                </div>

                <div class="bg-gray-50 px-6 py-4 flex justify-end gap-3 border-t border-gray-100">
                    <button type="button" class="cancel-btn px-4 py-2 text-gray-600 hover:bg-gray-200 rounded-lg transition-colors">Cancel</button>
                    <button type="submit" class="save-session bg-brand-red text-white px-6 py-2 rounded-lg font-medium hover:bg-red-700 transition-colors">Save Session</button>
                </div>
            </form>
        </div>
    </div>
</div>