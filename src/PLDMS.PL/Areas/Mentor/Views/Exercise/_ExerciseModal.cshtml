@model ExerciseFormDTO

<div id="addExerciseModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="modal-overlay fixed inset-0 bg-gray-900 bg-opacity-50 transition-opacity"></div>

    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-white rounded-xl shadow-xl w-full max-w-3xl overflow-hidden">
            <form id="createExerciseForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="ExerciseId" name="Id" value="" />

                <div class="p-6 max-h-[80vh] overflow-y-auto custom-scrollbar">
                    <h3 id="modalTitle" class="text-xl font-bold mb-6">Create New Exercise</h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Task Name</label>
                                <input name="Name" type="text" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none">
                                <span data-valmsg-for="Name" class="text-red-500 text-xs mt-1"></span>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700">Description</label>
                                <textarea id="exerciseDescriptionEditor" name="Description" rows="4" class="w-full mt-1 border rounded-lg p-2.5 focus:ring-brand-red outline-none"></textarea>
                                <span data-valmsg-for="Description" class="text-red-500 text-xs mt-1"></span>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700">Program</label>
                                    <select id="ProgramId" name="ProgramId" class="w-full mt-1 border rounded-lg p-2.5 outline-none">
                                        <option value="">Select...</option>
                                    </select>
                                    <span data-valmsg-for="ProgramId" class="text-red-500 text-xs mt-1"></span>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700">Difficulty</label>
                                    <select name="Difficulty" class="w-full mt-1 border rounded-lg p-2.5 outline-none">
                                        <option value="0">Easy</option>
                                        <option value="1">Medium</option>
                                        <option value="2">Hard</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Supported Languages</label>
                                <div class="flex flex-wrap gap-3">
                                    @foreach (var lang in Enum.GetValues(typeof(ProgrammingLanguage)).Cast<ProgrammingLanguage>())
                                    {
                                        <label class="flex items-center gap-1 text-sm">
                                            <input type="checkbox"
                                                name="Languages"
                                                value="@((int)lang)"
                                                class="accent-brand-red" />
                                            @lang
                                        </label>
                                    }
                                </div>
                                <span data-valmsg-for="Languages" class="text-red-500 text-xs mt-1"></span>
                            </div>
                        </div>

                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                            <div class="flex justify-between items-center mb-4">
                                <label class="block text-sm font-bold text-gray-800">Test Cases</label>
                                <button type="button" id="addTestCaseBtn" class="text-xs bg-white border border-gray-300 px-2 py-1 rounded hover:bg-gray-100 flex items-center gap-1">
                                    <i class="ph ph-plus"></i> Add Case
                                </button>
                            </div>

                            <div id="testCasesContainer" class="space-y-4">
                            </div>
                            <span data-valmsg-for="TestCases" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-gray-50 px-6 py-4 flex justify-end gap-3 border-t">
                    <button type="button" class="cancel-btn px-4 py-2 text-gray-600 hover:bg-gray-200 rounded-lg">Cancel</button>
                    <button type="submit" class="save-btn bg-brand-red text-white px-6 py-2 rounded-lg font-medium hover:bg-red-700 transition-colors">Save Task</button>
                </div>
            </form>
        </div>
    </div>
</div>

<template id="testCaseTemplate">
    <div class="test-case-row bg-white p-3 rounded border border-gray-200 relative group">
        <button type="button" class="remove-test-case absolute top-2 right-2 text-gray-400 hover:text-red-500 hidden group-hover:block">
            <i class="ph ph-x-circle text-lg"></i>
        </button>
        <div class="grid grid-cols-2 gap-3 mt-2">
            <div>
                <label class="text-xs text-gray-500">Input</label>
                <textarea class="tc-input w-full border rounded p-1.5 text-sm font-mono outline-none focus:border-brand-red" rows="2"></textarea>
            </div>
            <div>
                <label class="text-xs text-gray-500">Expected Output</label>
                <textarea class="tc-output w-full border rounded p-1.5 text-sm font-mono outline-none focus:border-brand-red" rows="2"></textarea>
            </div>
        </div>
        <div class="mt-2">
            <label class="flex items-center gap-2 text-xs font-medium text-gray-600">
                <input type="checkbox" class="tc-is-example accent-brand-red size-3.5" />
                Mark as Example (Visible to Students)
            </label>
        </div>
    </div>
</template>