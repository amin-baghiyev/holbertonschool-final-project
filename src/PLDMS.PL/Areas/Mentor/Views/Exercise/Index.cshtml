@model ExerciseVM

@{
    var hasSearch = !string.IsNullOrWhiteSpace(Context.Request.Query["q"]) ||
                    !string.IsNullOrWhiteSpace(Context.Request.Query["difficulty"]) ||
                    !string.IsNullOrWhiteSpace(Context.Request.Query["programId"]);

    var startItem = Model.TotalCount == 0 ? 0 : Model.CurrentPage * Model.PageSize + 1;
    var endItem = Math.Min((Model.CurrentPage + 1) * Model.PageSize, Model.TotalCount);
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0">
    <h1 class="text-xl font-bold text-gray-800">Exercises</h1>
    <button class="add-exercise flex items-center gap-2 bg-brand-red hover:bg-red-700 text-white px-5 py-2.5 rounded-lg font-medium transition-all shadow-sm">
        <i class="ph ph-plus-circle text-lg"></i>
        <span class="hidden sm:inline">Add Exercise</span>
    </button>
    <partial name="_ExerciseModal" model="new ExerciseFormDTO()" />
</header>

<div class="flex-1 flex flex-col overflow-hidden p-8">

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 shrink-0">
        <div>
            <h2 class="text-lg font-semibold text-gray-900">Programming Tasks</h2>
            <p class="text-sm text-gray-500">Manage coding exercises and test cases.</p>
        </div>

        <div class="flex gap-3">
            <form asp-action="Index" method="get" class="flex flex-wrap gap-3 items-center">

                <select name="onlyActive" class="bg-white border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-red/20 transition-all">
                    <option value="true" selected="@(Context.Request.Query["onlyActive"] == "true" || string.IsNullOrEmpty(Context.Request.Query["onlyActive"]))">Active Only</option>
                    <option value="false" selected="@(Context.Request.Query["onlyActive"] == "false")">Include Deactives</option>
                </select>

                <select name="difficulty" class="bg-white border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-red/20 transition-all">
                    <option value="">All Difficulties</option>
                    <option value="Easy" selected="@(Context.Request.Query["difficulty"] == "Easy")">Easy</option>
                    <option value="Medium" selected="@(Context.Request.Query["difficulty"] == "Medium")">Medium</option>
                    <option value="Hard" selected="@(Context.Request.Query["difficulty"] == "Hard")">Hard</option>
                </select>

                <select name="programId" class="bg-white border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand-red/20 transition-all" asp-items="ViewBag.Programs">
                    <option value="">All Programs</option>
                </select>

                <div class="flex items-center bg-white border rounded-lg px-3 py-2 focus-within:ring-2 focus-within:ring-brand-red/20 transition-all">
                    <i class="ph ph-magnifying-glass text-gray-400 mr-2"></i>
                    <input type="text" name="q" value="@Context.Request.Query["q"]" placeholder="Search task name..." class="outline-none text-sm w-40 md:w-56 bg-transparent">
                    @if (hasSearch)
                    {
                        <a asp-action="Index" class="ml-2 text-gray-400 hover:text-brand-red"><i class="ph ph-x-circle"></i></a>
                    }
                </div>

                <button type="submit" class="bg-brand-red hover:bg-red-700 py-2.5 px-4 rounded-lg transition-all shadow-sm">
                    <i class="ph ph-magnifying-glass text-white text-lg"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="flex-1 flex flex-col bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">

        <div class="flex-1 overflow-y-auto">
            @if (Model.Exercises != null && Model.Exercises.Count != 0)
            {
                <table class="min-w-full">
                    <thead class="sticky top-0 bg-gray-50 z-10 shadow-[0_1px_0_0_#e5e7eb]">
                        <tr class="text-sm font-semibold text-gray-600">
                            <th class="px-6 py-4 text-left">Task Name</th>
                            <th class="px-6 py-4 text-center">Program</th>
                            <th class="px-6 py-4 text-center">Difficulty</th>
                            <th class="px-6 py-4 text-center">Languages</th>
                            <th class="px-6 py-4 text-center">Status</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-sm">
                        @foreach (var item in Model.Exercises)
                        {
                            var isDeleted = item.IsDeleted;
                            var actionType = isDeleted ? "Activate" : "Deactivate";
                            var diffColor = item.Difficulty.ToString() == "Easy" ? "bg-green-100 text-green-700" :
                            item.Difficulty.ToString() == "Medium" ? "bg-yellow-100 text-yellow-700" : "bg-red-100 text-red-700";

                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 font-medium text-gray-900">
                                    <div class="flex flex-col">
                                        <span>@item.Name</span>
                                        <span class="text-xs text-gray-400">ID: #@item.Id</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center text-gray-600">@item.ProgramName</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-2.5 py-1 @diffColor rounded text-xs font-bold uppercase tracking-wider">
                                        @item.Difficulty
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center text-gray-600">
                                    <div class="flex items-center justify-center gap-1 flex-wrap">
                                        @foreach (var lang in item.Languages)
                                        {
                                            <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-xs">@lang</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-2.5 py-1 @(isDeleted ? "bg-red-50 text-red-700" : "bg-green-50 text-green-700") rounded-lg font-medium">
                                        @(isDeleted ? "Deactive" : "Active")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <button class="edit-btn text-gray-500 hover:text-blue-600 mr-2" data-id="@item.Id">
                                        <i class="ph ph-pencil-simple text-lg"></i>
                                    </button>

                                    <button data-url="@Url.Action(actionType, "Exercise", new { id = item.Id })"
                                            data-type="@actionType"
                                            data-name="@item.Name"
                                            class="power-btn text-gray-500 @(isDeleted ? "hover:text-green-600" : "hover:text-brand-red")">
                                        <i class="ph ph-power text-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="py-12 text-center bg-gray-50 border border-dashed rounded-xl m-4">
                    <i class="ph ph-code text-4xl text-gray-300 mb-2"></i>
                    <p class="text-gray-500">No exercises found matching your criteria.</p>
                </div>
            }
        </div>

        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 bg-white shrink-0">

            <div class="flex items-center gap-6">
                <div class="hidden sm:block text-sm text-gray-500">
                    Showing
                    <span class="font-medium text-gray-900">@startItem</span>
                    -
                    <span class="font-medium text-gray-900">@endItem</span>
                    of
                    <span class="font-medium text-gray-900">@Model.TotalCount</span>
                    results
                </div>

                <form method="get" asp-action="Index" class="flex items-center gap-2 text-sm">
                    <input type="hidden" name="q" value="@Context.Request.Query["q"]" />
                    <input type="hidden" name="difficulty" value="@Context.Request.Query["difficulty"]" />
                    <input type="hidden" name="programId" value="@Context.Request.Query["programId"]" />
                    <input type="hidden" name="onlyActive" value="@Context.Request.Query["onlyActive"]" />
                    <input type="hidden" name="page" value="0" />

                    <span class="text-gray-500">Show</span>

                    <select name="pageSize"
                            onchange="this.form.submit()"
                            class="border border-gray-200 rounded-lg px-2 py-1 text-gray-700 focus:outline-none focus:ring-1 focus:ring-red-400">
                        <option value="5" selected="@(Model.PageSize == 5)">5</option>
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="15" selected="@(Model.PageSize == 15)">15</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    </select>

                    <span class="text-gray-500">per page</span>
                </form>
            </div>

            <div class="flex gap-2">
                <a asp-action="Index"
                   asp-route-q="@Context.Request.Query["q"]"
                   asp-route-difficulty="@Context.Request.Query["difficulty"]"
                   asp-route-programId="@Context.Request.Query["programId"]"
                   asp-route-onlyActive="@Context.Request.Query["onlyActive"]"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(Model.CurrentPage == 0 ? "border-gray-200 text-gray-400 bg-gray-50 pointer-events-none" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    Previous
                </a>

                <div class="hidden sm:flex gap-1">
                    @for (var i = 0; i < totalPages; i++)
                    {
                        <a asp-action="Index"
                           asp-route-q="@Context.Request.Query["q"]"
                           asp-route-difficulty="@Context.Request.Query["difficulty"]"
                           asp-route-programId="@Context.Request.Query["programId"]"
                           asp-route-onlyActive="@Context.Request.Query["onlyActive"]"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize"
                           class="px-3 py-1.5 border rounded-lg text-sm font-medium transition-colors @(i == Model.CurrentPage ? "border-red-200 bg-red-50 text-red-600" : "border-transparent text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                            @(i + 1)
                        </a>
                    }
                </div>

                <a asp-action="Index"
                   asp-route-q="@Context.Request.Query["q"]"
                   asp-route-difficulty="@Context.Request.Query["difficulty"]"
                   asp-route-programId="@Context.Request.Query["programId"]"
                   asp-route-onlyActive="@Context.Request.Query["onlyActive"]"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   class="px-3 py-1.5 border rounded-lg text-sm font-medium @(Model.CurrentPage >= totalPages - 1 ? "border-gray-200 text-gray-400 bg-gray-50 pointer-events-none" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    Next
                </a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/mentor/exercise.js"></script>
}