<div id="assignReviewModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="modal-overlay fixed inset-0 bg-gray-900/50 transition-opacity"></div>
    
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-white rounded-xl shadow-xl w-full max-w-2xl overflow-hidden flex flex-col h-[600px] max-h-[90vh]">
            
            <div class="p-6 border-b border-gray-100 flex flex-col gap-4 bg-white sticky top-0 z-10 shrink-0">
                <div class="flex justify-between items-center">
                    <div>
                        <h3 class="text-xl font-bold text-gray-800">Assign Peer Reviewer</h3>
                        <p class="text-sm text-gray-500 mt-1">Select a student to review <span id="targetGroupName" class="font-bold text-brand-red"></span></p>
                    </div>
                    <button type="button" class="close-modal-btn text-gray-400 hover:text-gray-600">
                        <i class="ph ph-x text-2xl"></i>
                    </button>
                </div>
                <div class="relative">
                    <i class="ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" id="searchReviewerInput" placeholder="Search students by name or email..." class="w-full pl-10 pr-4 py-2 border rounded-lg outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-all">
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-4" id="reviewerListContainer">
                <div class="flex flex-col items-center justify-center py-12 text-gray-400">
                    <i class="ph ph-users-three text-5xl mb-4 opacity-20"></i>
                    <p class="text-sm font-medium">Search for a student to begin</p>
                </div>
            </div>

            <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 flex justify-between items-center">
                <span class="text-sm text-gray-500" id="selectedReviewerText">No student selected</span>
                <div class="flex gap-3">
                    <button type="button" class="close-modal-btn px-4 py-2 text-gray-600 hover:bg-gray-200 rounded-lg">Cancel</button>
                    <button type="button" id="confirmAssignReview" disabled class="bg-brand-red text-white px-6 py-2 rounded-lg font-medium shadow-sm hover:bg-red-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                        Assign Review
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
